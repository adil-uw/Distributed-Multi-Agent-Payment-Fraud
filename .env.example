# Copy to .env and adjust for your machine.
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=fraud_detection

# Agent base URLs (no trailing /evaluate — coordinator appends /evaluate)
BEHAVIORAL_AGENT_URL=http://127.0.0.1:8001
GEO_AGENT_URL=http://127.0.0.1:8002
MERCHANT_AGENT_URL=http://127.0.0.1:8003
HISTORY_AGENT_URL=http://127.0.0.1:8004
AGENT_REQUEST_TIMEOUT_SECONDS=10
